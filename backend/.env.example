# Copie para backend/.env e preencha com o RDS/Aurora PostgreSQL na AWS.
#
# RDS: Console AWS → RDS → sua instância → Endpoint
# Ex.: portal-ciop.xxxxx.us-east-1.rds.amazonaws.com
#
# Desenvolvimento local (docker compose up -d em backend/):
# DATABASE_URL=postgresql://portal_user:portal_dev@localhost:5432/portalciop

DATABASE_URL=postgresql://portal_user:SENHA@SEU-HOST.rds.amazonaws.com:5432/portalciop
PORT=3000

# Origens permitidas (portal estático). Separe por vírgula.
CORS_ORIGINS=https://portal-ciop.web.app,http://localhost:5173,http://127.0.0.1:5500,http://localhost:3000

# Chave para jobs GitHub Actions (importação). Header: X-Portal-Api-Key
PORTAL_API_KEY=

# Firebase Admin — caminho do JSON da service account (mesmo projeto portal-ciop)
GOOGLE_APPLICATION_CREDENTIALS=../.secrets/serviceAccount.json
